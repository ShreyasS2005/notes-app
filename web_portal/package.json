{
  "name": "smartnotes-web-portal",
  "version": "1.0.0",
  "description": "SmartNotes AI Web Portal with React + Selenium E2E Testing",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "selenium-webdriver": "^4.16.0",
    "xlsx": "^0.18.5",
    "fs-extra": "^11.1.1",
    "gh-pages": "^6.0.0",
    "chromedriver": "^120.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "node tests/seleniumTest.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "homepage": "http://localhost:3000"
}
